# =============================================================================
# SAYIBI AI — Configuration Backend
# Copier ce fichier en .env et remplir avec vos vraies clés
# Ne jamais committer le fichier .env ni les JSON de compte de service.
# =============================================================================

# JWT
JWT_SECRET=VOTRE_SECRET_ICI_GENERER_AVEC_secrets.token_urlsafe(64)
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# LLM APIs
GROQ_API_KEY=gsk_...
GEMINI_API_KEY=AI...
# Ordre de bascule si quota / 404 / surcharge (virgules). Même logique que le chat / OCR.
# GEMINI_MODELS=gemini-2.5-flash,gemini-3-flash,gemini-3.1-flash-lite,gemini-2.5-flash-lite,gemini-2.0-flash,gemini-1.5-flash
MISTRAL_API_KEY=...

# Recherche Web
TAVILY_API_KEY=tvly-...
SERPER_API_KEY=

# TTS
ELEVENLABS_API_KEY=...

# Redis (Upstash) — URL HTTPS du endpoint REST ou redis:// selon votre client
UPSTASH_REDIS_URL=https://xxxx.upstash.io
UPSTASH_REDIS_TOKEN=...

# Pinecone (Base vectorielle)
PINECONE_API_KEY=...
PINECONE_INDEX_NAME=sayibi-memory
PINECONE_ENVIRONMENT=us-east-1

# Cloudflare R2 (API S3 — pas la « Global API Key » du compte)
# Dashboard → R2 → Account details → Account ID + « Manage R2 API Tokens »
# Créer un token : Object Read & Write (ou Admin) sur le bucket ; copier Access Key ID + Secret Access Key une seule fois.
R2_ACCOUNT_ID=...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET_NAME=sayibi-files
# URL publique (domaine r2.dev ou custom) — optionnel pour les tests API
R2_PUBLIC_URL=https://xxxxx.r2.dev
# Si le bucket est en juridiction EU : mettre eu (sinon laisser vide)
# R2_JURISDICTION=eu
# Surcharge rare : endpoint S3 complet (FedRAMP, cas particuliers)
# R2_S3_ENDPOINT=https://VOTRE_ACCOUNT_ID.eu.r2.cloudflarestorage.com

# Firebase Cloud Messaging v1 (recommandé) — compte de service
# Option A : chemin local vers le JSON téléchargé depuis Firebase Console
FIREBASE_CREDENTIALS_PATH=./credentials/firebase-service-account.json
# Option B (Render / CI) : JSON complet sur une ligne (variable secrète)
# FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"...",...}

# Ancienne API FCM (legacy Server Key) — dépréciée ; laisser vide si vous utilisez v1
FCM_SERVER_KEY=

# Secret pour POST /api/v1/internal/fcm-test (en-tête X-Sayibi-Internal-Secret)
# Générer avec : python -c "import secrets; print(secrets.token_urlsafe(32))"
SAYIBI_INTERNAL_SECRET=

# Environnement
ENVIRONMENT=production
LOG_LEVEL=INFO
# Sans domaine custom : localhost suffit pour Flutter web / tests ; ajoutez https://votre-domaine.com quand prêt.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Développement (optionnel)
DEBUG=false
# *.onrender.com couvre tout sous-domaine Render (sayibi-backend-xxxx.onrender.com).
TRUSTED_HOSTS=*.onrender.com,sayibi-backend.onrender.com,api.sayibi.app,localhost,127.0.0.1

# Kokoro TTS (optionnel)
KOKORO_TTS_URL=

# Tests (test_apis.py) — URL du backend déployé pour GET /health (optionnel)
# SAYIBI_DEPLOY_URL=https://sayibi-backend.onrender.com
